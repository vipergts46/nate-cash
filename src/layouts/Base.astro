---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = "Nate Cash",
  description = "Cybersecurity leader, Marine veteran, lifelong tinkerer. Personal site of Nate Cash.",
  pathname = Astro.url.pathname,
} = Astro.props;

const fullTitle = title === "Nate Cash" ? title : `${title} — Nate Cash`;
const canonical = new URL(pathname, "https://nate.cash").toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex flex-col">
    <Header pathname={pathname} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
