---
import Base from "../../layouts/Base.astro";

const faqs = [
  {
    q: "Why is my protein target so high?",
    a: "MacroPilot computes protein first, scaled to your age and bodyweight. Most apps undershoot protein because they default to outdated targets. Yours isn't wrong — it's likely correct, just unfamiliar.",
  },
  {
    q: "Why does the app cap my rate of loss?",
    a: "Faster than ~1 lb/week is mostly water and lean tissue. The cap protects your muscle and keeps the loss durable. You can override the cap, but the default exists for a reason.",
  },
  {
    q: "Why don't I see cooking instructions when I save a recipe?",
    a: "MacroPilot links back to the original author for instructions instead of copying them. It's a respect-and-licensing thing — you'll always see the source name, ingredients, and a link.",
  },
  {
    q: "How do I export or delete my data?",
    a: "Settings → Account → Export or Delete. If anything is stuck, email me@nate.cash and Nate will handle it manually.",
  },
  {
    q: "I found a bug.",
    a: "Email me@nate.cash with what happened, what device/OS you're on, and a screenshot if you can. Crash reports help — and a real human reads them.",
  },
];
---
<Base
  title="MacroPilot — Support"
  description="Get help with MacroPilot. FAQ and a direct contact."
>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-20">
    <p class="display-eyebrow mb-4">// MACROPILOT // SUPPORT</p>
    <h1 class="text-4xl md:text-5xl">Need a hand?</h1>
    <p class="mt-6 text-lg leading-relaxed text-[color:var(--color-muted)]">
      Real human at the other end. Fastest answer is usually email.
    </p>

    <a href="mailto:me@nate.cash" class="mt-8 inline-flex items-center gap-3 rounded-xl border border-[color:var(--color-ink)] bg-[color:var(--color-ink)] px-6 py-3 text-sm no-underline text-[color:var(--color-bg)] hover:bg-[color:var(--color-accent)] hover:border-[color:var(--color-accent)] dark:border-[color:var(--color-bg)] dark:bg-[color:var(--color-bg)] dark:text-[color:var(--color-ink)]">
      Email me@nate.cash →
    </a>

    <div class="mt-16">
      <p class="display-eyebrow mb-6">// FAQ</p>
      <div class="space-y-6">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-[color:var(--color-ink)]/10 p-5 dark:border-[color:var(--color-bg)]/10">
            <summary class="cursor-pointer text-lg list-none flex items-start justify-between gap-4">
              <span>{f.q}</span>
              <span class="text-[color:var(--color-accent)] transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-[color:var(--color-muted)]">{f.a}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-16 rounded-xl border-l-4 border-[color:var(--color-secondary)] bg-[color:var(--color-secondary)]/5 p-6 dark:bg-[color:var(--color-primary)]/10">
      <p class="display-eyebrow mb-2">// STILL STUCK?</p>
      <p class="text-base">
        Email <a href="mailto:me@nate.cash">me@nate.cash</a>. Include your device, OS version, and a screenshot if you can. Replies usually land within a day.
      </p>
    </div>
  </section>
</Base>
