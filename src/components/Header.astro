---
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

const nav = [
  { href: "/about", label: "About" },
  { href: "/consulting", label: "Consulting" },
  { href: "/macropilot", label: "MacroPilot" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) =>
  pathname === href || (href !== "/" && pathname.startsWith(href));
---
<header class="border-b border-[color:var(--color-ink)]/10">
  <div class="mx-auto flex max-w-6xl flex-col items-start gap-3 px-6 py-5 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
    <a href="/" class="display-eyebrow !text-[color:var(--color-ink)] !text-sm dark:!text-[color:var(--color-bg)] no-underline whitespace-nowrap">
      NATE CASH
    </a>
    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm sm:gap-7">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "no-underline tracking-wide",
            isActive(href)
              ? "text-[color:var(--color-accent)]"
              : "text-[color:var(--color-ink)] dark:text-[color:var(--color-bg)] hover:text-[color:var(--color-accent)]",
          ]}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
