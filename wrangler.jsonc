{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nate-cash",
  "compatibility_date": "2026-06-27",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
